<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurfaceVariant"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <!-- Interruption Icon -->
            <LinearLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_circle_timer"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏸️"
                    android:textSize="40sp" />
            </LinearLayout>

            <!-- Title -->
            <TextView
                android:id="@+id/tvInterruptedTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Session Interrupted"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <!-- Message -->
            <TextView
                android:id="@+id/tvInterruptedMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="It's okay to take a break, but don't give up on your goals!"
                android:textSize="16sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <!-- Motivational Message -->
            <TextView
                android:id="@+id/tvMotivationalMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You made good progress! Every minute counts."
                android:textSize="18sp"
                android:textStyle="italic"
                android:textColor="@color/primary_60"
                android:gravity="center"
                android:background="@drawable/bg_card"
                android:padding="16dp" />
        </LinearLayout>

        <!-- Session Summary Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="?attr/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Card Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="What You Accomplished"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="20dp" />

                <!-- Summary Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Focus Time Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="@drawable/bg_stat_box_green"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Focus Time Completed"
                            android:textSize="16sp"
                            android:textColor="@color/white" />

                        <TextView
                            android:id="@+id/tvFocusTimeCompleted"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="25 min"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/white" />
                    </LinearLayout>

                    <!-- Sessions Completed Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="@drawable/bg_stat_box_purple"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Sessions Completed"
                            android:textSize="16sp"
                            android:textColor="@color/white" />

                        <TextView
                            android:id="@+id/tvSessionsCompleted"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2 sessions"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/white" />
                    </LinearLayout>

                    <!-- Breaks Taken Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="@color/gray_light"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Breaks Taken"
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSurface" />

                        <TextView
                            android:id="@+id/tvBreaksTaken"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1 break"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface" />
                    </LinearLayout>

                    <!-- Focus Type Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="?attr/colorSurfaceVariant">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Focus Type"
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSurface" />

                        <TextView
                            android:id="@+id/tvFocusType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pomodoro"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_60" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Try Again Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTryAgain"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="🔄 Try Again"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/primary_60"
                android:elevation="8dp"
                app:cornerRadius="16dp"
                android:layout_marginBottom="16dp" />

            <!-- Go Home Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoHome"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="🏠 Go Home"
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurface"
                android:backgroundTint="?attr/colorSurface"
                android:elevation="4dp"
                app:cornerRadius="16dp"
                app:strokeColor="@color/primary_60"
                app:strokeWidth="2dp"
                android:layout_marginBottom="12dp" />

            <!-- View Stats Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewStats"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="📊 View Statistics"
                android:textSize="16dp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:backgroundTint="@android:color/transparent"
                android:elevation="0dp"
                app:cornerRadius="16dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
