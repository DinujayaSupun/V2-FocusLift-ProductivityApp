<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/white"
    android:padding="32dp">

    <!-- Logo Container -->
    <LinearLayout
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="32dp">

        <!-- Lightbulb Logo Placeholder -->
        <ImageView
            android:id="@+id/logo_placeholder"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_lightbulb"
            android:tint="@color/primary_60"
            android:background="@drawable/bg_circle_timer"
            android:padding="16dp" />

        <!-- Progress Arrows -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_arrow_back"
                android:rotation="270"
                android:tint="@color/accent_10"
                android:layout_marginEnd="4dp" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_arrow_back"
                android:rotation="270"
                android:tint="@color/accent_10" />
        </LinearLayout>
    </LinearLayout>

    <!-- App Name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="8dp"
        android:fontFamily="sans-serif-black" />

    <!-- Tagline -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/splash_tagline"
        android:textSize="16sp"
        android:textColor="@color/primary_60"
        android:layout_marginBottom="48dp"
        android:fontFamily="sans-serif-light" />

    <!-- Loading Indicator -->
    <ProgressBar
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/primary_60"
        style="?android:attr/progressBarStyle" />

    <!-- Version Info -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_version"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="48dp"
        android:fontFamily="sans-serif-light" />

</LinearLayout>
